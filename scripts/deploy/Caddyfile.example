# Caddy — proxy reverso com HTTPS automático (Let's Encrypt) para a API
# Mangaba (multi-tenant). Expõe SOMENTE o roteador :8642 ao mundo.
#
# 1) Troque api.seudominio.com pelo seu domínio (aponte o DNS A/AAAA para o IP).
# 2) Instale o Caddy: https://caddyserver.com/docs/install
# 3) Rode:  sudo caddy run --config scripts/deploy/Caddyfile.example
#    (ou copie para /etc/caddy/Caddyfile e use o serviço do sistema)
#
# IMPORTANTE:
#   • NÃO exponha o dashboard (:9119) nem os backends dedicados (:8700+).
#     Eles devem ficar só em 127.0.0.1. Este proxy publica apenas a API.
#   • O gateway principal precisa de API_SERVER_HOST=0.0.0.0 e um
#     API_SERVER_KEY forte (veja setup-public.sh). Os clientes usam as
#     chaves mk_live_… deles; a API_SERVER_KEY é só do operador (admin).

api.seudominio.com {
	# TLS automático via Let's Encrypt (precisa porta 80/443 abertas).
	encode gzip

	# Streaming (SSE) precisa de flush sem buffer.
	reverse_proxy 127.0.0.1:8642 {
		flush_interval -1
		header_up Host {host}
		header_up X-Real-IP {remote_host}
	}

	# Limite de corpo (conversas longas com ferramentas).
	request_body {
		max_size 12MB
	}

	log {
		output file /var/log/caddy/mangaba-api.log
	}
}

